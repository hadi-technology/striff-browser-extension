  S.ensureFocusZoom = (elem) => {
    const point = S.getElementCenterClientPoint(elem);
    if (!point) return false;
    const view = S.getStriffScrollEl();
    const svg = (S.__striffsSvg || view?.querySelector('svg'));
    if (!view || !svg) return false;
