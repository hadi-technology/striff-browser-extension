    if (Number.isFinite(widthAttr) && widthAttr > 0 && Number.isFinite(heightAttr) && heightAttr > 0) {
      return { width: widthAttr, height: heightAttr };
    }
    try {
      const bbox = svg.getBBox?.();
      if (bbox && Number(bbox.width) > 0 && Number(bbox.height) > 0) {
