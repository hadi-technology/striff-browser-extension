{
  "manifest_version": 3,
  "name": "Striffs for GitHub",
  "description": "Adds an architectural diff tab to GitHub pull requests.",
  "version": "1.0.4",
  "minimum_chrome_version": "111",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "*://github.com/*",
    "*://*.github.com/*",
    "https://codeload.github.com/*",
    "*://*.striff.io/*",
    "https://striffs-config.tor1.cdn.digitaloceanspaces.com/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://github.com/*",
        "*://*.github.com/*"
      ],
      "js": [
        "src/webext-shim.js",
        "src/pr-metadata-utils.js",
        "src/striffs-config-utils.js",
        "src/striffs.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "html/options.html",
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/striff-16.png",
      "32": "icons/striff-32.png",
      "48": "icons/striff-48.png",
      "128": "icons/striff-128.png"
    }
  },
  "icons": {
    "16": "icons/striff-16.png",
    "32": "icons/striff-32.png",
    "48": "icons/striff-48.png",
    "128": "icons/striff-128.png"
  }
}
