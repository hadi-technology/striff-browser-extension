{
  "manifest_version": 3,
  "name": "Striffs for GitHub",
  "description": "Adds an architectural diff tab to GitHub pull requests.",
  "version": "1.0.2",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "*://github.com/*",
    "*://*.github.com/*",
    "https://codeload.github.com/*",
    "https://striffs-config.tor1.cdn.digitaloceanspaces.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://github.com/*",
        "*://*.github.com/*"
      ],
      "js": [
        "lib/fflate.min.js",
        "src/webext-shim.js",
        "src/pr-metadata-utils.js",
        "src/striffs.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "html/options.html",
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/clarity-bot16.png",
      "48": "icons/clarity-bot48.png",
      "128": "icons/clarity-bot128.png"
    }
  }
}
