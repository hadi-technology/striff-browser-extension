{
  "manifest_version": 3,
  "name": "Striffs for GitHub",
  "description": "Adds an architectural diff tab to GitHub pull requests.",
  "version": "1.0",
  "permissions": ["storage", "tabs", "scripting", "webRequest", "webNavigation", "downloads"],
  "host_permissions": ["*://*.github.com/*", "https://codeload.github.com/*", "*://localhost:8081/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.github.com/*/*/pull/*/files",
        "*://*.github.com/*/*/pull/*/files*"
      ],
      "js": [
        "lib/fflate.min.js",
        "lib/panzoom.min.js",
        "src/striffs-core.js",
        "src/striffs-dom-ui.js",
        "src/striffs-pr.js",
        "src/striffs-render-cache.js",
        "src/striffs-events-boot.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "html/options.html",
  "action": {
    "default_popup": "html/popup.html",
    "default_icon": {
      "16": "icons/clarity-bot16.png",
      "48": "icons/clarity-bot48.png",
      "128": "icons/clarity-bot128.png"
    }
  }
}
