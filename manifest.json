{
  "manifest_version": 3,
  "name": "Striffs for GitHub",
  "description": "Adds an architectural diff tab to GitHub pull requests.",
  "version": "1.0",
  "permissions": ["storage", "tabs", "scripting", "webRequest", "webNavigation"],
  "host_permissions": ["*://*.github.com/*", "https://codeload.github.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.github.com/*/pull/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["panzoom.min.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/clarity-bot16.png",
      "48": "icons/clarity-bot48.png",
      "128": "icons/clarity-bot128.png"
    }
  }
}
