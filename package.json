{
  "name": "striff-browser-extension",
  "version": "1.0.4",
  "description": "A cross-browser GitHub extension that adds a **\"Striffs\"** tab to pull request pages. This tab displays architectural diffs as interactive SVG diagrams, making code review more transparent and insightful.",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:unit": "node --test test/*.test.js",
    "test:live": "node test/manual-smoke-live.js",
    "test:ui": "node test/manual-smoke-live.js && NEW_UI=1 node test/manual-smoke-live.js",
    "test:visual": "node test/striffs-visual-tests.js && NEW_UI=1 node test/striffs-visual-tests.js",
    "test:login": "node test/login-github.js",
    "package:extension": "node scripts/package-extension.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hadii-tech/striff-browser-extension.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/hadii-tech/striff-browser-extension/issues"
  },
  "homepage": "https://github.com/hadii-tech/striff-browser-extension#readme",
  "devDependencies": {
    "playwright": "^1.58.1"
  }
}
